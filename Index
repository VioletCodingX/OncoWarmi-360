<div class="app">
<!-- ═══ SIDEBAR ═══ -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon">🌸</div>
    <div>
      <div class="logo-text">OncoWarmi 360</div>
      <div style="display:flex;flex-direction:column;gap:1px;">
          <div style="font-size:10px;color:#7c3aed;font-weight:600;">🇵🇪 Navegación Diagnóstica · INEN</div>
          <div style="font-size:9px;color:#a78bfa;">🌿 Usuta Taripay Ñan · INEN</div>
          <div style="font-size:9px;color:#c4b5fd;">🏔️ Onkuri Thakhi · INEN</div>
        </div>
    </div>
  </div>

  <div class="nav-section">
    <div class="nav-section-label" data-t="sec_principal">PRINCIPAL</div>
    <div class="nav-item active" onclick="show('inicio')"    id="ni-inicio">   <span class="nav-icon">🏠</span><span data-t="nav_inicio">Inicio</span></div>
    <div class="nav-item"       onclick="show('ruta')"       id="ni-ruta">     <span class="nav-icon">🗺️</span><span data-t="nav_ruta">Mi Ruta Diagnóstica</span></div>
    <div class="nav-item"       onclick="show('sms')"        id="ni-sms">      <span class="nav-icon">💬</span><span data-t="nav_sms">WhatsApp OncoWarmi</span></div>
    <div class="nav-item"       onclick="show('checklist')"  id="ni-checklist"><span class="nav-icon">✅</span><span data-t="nav_check">¿Viajar hoy?</span></div>
    <div class="nav-item"       onclick="show('cuidador')"   id="ni-cuidador"> <span class="nav-icon">👨‍👩‍👧</span><span data-t="nav_cuid">Modo Cuidador</span></div>
  </div>
  <div class="nav-section" style="margin-top:4px;">
    <div class="nav-section-label" data-t="sec_rutas">RUTAS DE ATENCIÓN</div>
    <div class="nav-item" onclick="show('psicologia')" id="ni-psicologia"><span class="nav-icon">🧠</span><span data-t="nav_psico">Ruta Psicológica</span><span class="nav-new">NUEVO</span></div>
    <div class="nav-item" onclick="show('dolor')"      id="ni-dolor">     <span class="nav-icon">💊</span><span data-t="nav_dolor">Manejo del Dolor</span><span class="nav-new">NUEVO</span></div>
  </div>
  <div class="nav-section" style="margin-top:4px;">
    <div class="nav-section-label" data-t="sec_tools">HERRAMIENTAS</div>
    <div class="nav-item" onclick="show('traductor')" id="ni-traductor"><span class="nav-icon">🔤</span><span data-t="nav_trad">Traductor Médico</span></div>
    <div class="nav-item" onclick="show('llamada')"   id="ni-llamada">  <span class="nav-icon">📞</span><span data-t="nav_call">WarmiVoz</span></div>
    <div class="nav-item" onclick="show('mapa')"      id="ni-mapa">     <span class="nav-icon">📍</span><span data-t="nav_mapa">Mapa INEN</span></div>
  </div>
  <div class="nav-section" style="margin-top:4px;">
    <div class="nav-section-label" data-t="sec_inen">INEN · PROFESIONALES</div>
    <div class="nav-item" onclick="show('dashboard')" id="ni-dashboard"><span class="nav-icon">📊</span><span data-t="nav_dash">Panel · Semáforo IA</span></div>
    <div class="nav-item" onclick="show('briefing')"  id="ni-briefing"> <span class="nav-icon">📋</span><span data-t="nav_brief">Briefing al Médico</span></div>
  </div>

  <div class="sidebar-user">
    <div class="user-avatar">M</div>
    <div>
      <div class="user-name">María Quispe</div>
      <div class="user-region" data-t="user_region">Ayacucho · Día 3</div>
    </div>
  </div>
</aside>

<!-- ═══ MAIN ═══ -->
<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleDrawer()">☰</button>
    <div style="flex:1;">
      <div class="topbar-title" id="tb-title">Inicio</div>
      <div class="topbar-sub"   id="tb-sub">Bienvenida a tu navegadora OncoWarmi</div>
    </div>
    <div class="lang-switcher">
      <button class="lang-btn active" onclick="setLang('es')" id="lb-es">🇵🇪 ES</button>
      <button class="lang-btn"        onclick="setLang('qu')" id="lb-qu">🌿 QU</button>
      <button class="lang-btn"        onclick="setLang('ay')" id="lb-ay">🏔️ AY</button>
    </div>
    <div class="status-pill"><div class="status-dot"></div><span data-t="status">En línea</span></div>
  </div>

  <div class="page-area">

  <!-- ══ INICIO ══ -->
  <div class="page active" id="page-inicio">
    <div class="hero">
      <div class="hero-tag" data-t="hero_tag">DIAGNÓSTICO EN CURSO · DÍA 3</div>
      <div class="hero-name" data-t="hero_name">Hola, María 👋</div>
      <div class="hero-sub"  data-t="hero_sub">Tu próximo paso está confirmado</div>
      <div class="hero-chips">
        <div class="hero-chip">📅 18 jun · 9:00 a.m.</div>
        <div class="hero-chip" data-t="chip_mod">📍 Módulo Admisión 3</div>
        <div class="hero-chip chip-green" data-t="chip_ref">✓ Referencia aceptada</div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card" style="border-top-color:var(--purple);">
        <div class="stat-label" data-t="st1_lbl">ETAPA</div>
        <div class="stat-val" style="color:var(--purple);">3/9</div>
        <div class="stat-sub" data-t="st1_sub">Apertura HC pendiente</div>
      </div>
      <div class="stat-card" style="border-top-color:var(--green);">
        <div class="stat-label" data-t="st2_lbl">DÍAS EN PROCESO</div>
        <div class="stat-val" style="color:var(--green);">3</div>
        <div class="stat-sub" data-t="st2_sub">⬇ Promedio: 4.9 días</div>
      </div>
      <div class="stat-card" style="border-top-color:var(--amber);">
        <div class="stat-label" data-t="st3_lbl">PRÓXIMA CITA</div>
        <div class="stat-val" style="color:var(--amber);">5d</div>
        <div class="stat-sub" data-t="st3_sub">Miércoles 18 jun</div>
      </div>
      <div class="stat-card" style="border-top-color:var(--pink);">
        <div class="stat-label" data-t="st4_lbl">VIAJES EVITADOS</div>
        <div class="stat-val" style="color:var(--pink);">2</div>
        <div class="stat-sub" data-t="st4_sub">Ahorro: S/ 240</div>
      </div>
    </div>

    <div class="alert alert-warn">
      <strong data-t="al1_tit">🌿 ¿Viajas desde Ayacucho?</strong>
      <span data-t="al1_bod">Tu resultado aún no está listo. No necesitas viajar hoy.</span>
      <div style="margin-top:8px;"><button class="btn btn-ghost btn-sm" onclick="show('checklist')" data-t="al1_btn">Ver checklist →</button></div>
    </div>
    <div class="alert alert-info">
      <strong data-t="al2_tit">📋 Documentos para el 18 jun</strong>
      <span data-t="al2_bod">DNI · Hoja de referencia · Informe médico · Resultados previos</span>
    </div>
    <div class="alert alert-pink" style="cursor:pointer;" onclick="show('psicologia')">
      <strong data-t="al3_tit">🧠 ¿Sientes ansiedad?</strong>
      <span data-t="al3_bod">Contamos con apoyo psicológico especializado. Toca para acceder →</span>
    </div>

    <div class="card" style="margin-top:4px;">
      <div style="font-size:13px;font-weight:700;margin-bottom:14px;" data-t="journey_tit">Tu recorrido</div>
      <div class="journey">
        <div class="step"><div class="step-circle done">✓</div><div class="step-body"><div class="step-title" data-t="j1_tit">Referencia REFCON</div><div class="step-desc" data-t="j1_des">Aceptada desde Huamanga</div></div></div>
        <div class="step"><div class="step-circle done">✓</div><div class="step-body"><div class="step-title" data-t="j2_tit">Registro en INEN</div><div class="step-desc" data-t="j2_des">Perfil creado · Sistema SISINEN</div></div></div>
        <div class="step"><div class="step-circle active">3</div><div class="step-body"><div class="step-title" data-t="j3_tit">Apertura Historia Clínica</div><div class="step-date">📅 18 jun · 9:00 a.m.</div></div></div>
        <div class="step"><div class="step-circle pending">4</div><div class="step-body"><div class="step-title" data-t="j4_tit">Consulta especialista</div><div class="step-desc" data-t="j4_des">Pendiente</div></div></div>
      </div>
      <button class="btn btn-outline btn-sm" onclick="show('ruta')" data-t="journey_btn">Ver ruta completa →</button>
    </div>
  </div>

  <!-- ══ MI RUTA ══ -->
  <div class="page" id="page-ruta">
    <div class="page-header">
      <h2 data-t="ruta_h">Mi Ruta Diagnóstica</h2>
      <p data-t="ruta_p">9 pasos · Tu proceso paso a paso</p>
    </div>
    <div class="card" style="margin-bottom:14px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <div style="font-size:13px;font-weight:700;" data-t="prog_tit">Progreso general</div>
        <div class="tag tag-purple" data-t="prog_val">2/9 completados</div>
      </div>
      <div style="background:var(--border);border-radius:10px;height:8px;">
        <div style="width:22%;height:100%;background:var(--purple);border-radius:10px;"></div>
      </div>
    </div>
    <div class="journey">
      <div class="step"><div class="step-circle done">✓</div><div class="step-body"><div class="step-title" data-t="r1_t">Referencia REFCON aprobada</div><div class="step-desc" data-t="r1_d">Establecimiento de salud Huamanga</div></div></div>
      <div class="step"><div class="step-circle done">✓</div><div class="step-body"><div class="step-title" data-t="r2_t">Registro en INEN</div><div class="step-desc" data-t="r2_d">Sistema SISINEN · Código paciente</div></div></div>
      <div class="step"><div class="step-circle active">3</div><div class="step-body"><div class="step-title" data-t="r3_t">Apertura Historia Clínica</div><div class="step-desc" data-t="r3_d">Módulo Admisión 3</div><div class="step-date">📅 18 jun · 9:00 a.m.</div></div></div>
      <div class="step"><div class="step-circle pending">4</div><div class="step-body"><div class="step-title" data-t="r4_t">Triaje oncológico</div><div class="step-desc" data-t="r4_d">Evaluación inicial de riesgo</div></div></div>
      <div class="step"><div class="step-circle pending">5</div><div class="step-body"><div class="step-title" data-t="r5_t">Exámenes de laboratorio</div><div class="step-desc" data-t="r5_d">Análisis y resultados</div></div></div>
      <div class="step"><div class="step-circle pending">6</div><div class="step-body"><div class="step-title" data-t="r6_t">Imágenes diagnósticas</div><div class="step-desc" data-t="r6_d">Ecografía / Mamografía / PAP</div></div></div>
      <div class="step"><div class="step-circle pending">7</div><div class="step-body"><div class="step-title" data-t="r7_t">Biopsia (si aplica)</div><div class="step-desc" data-t="r7_d">Resultado anatomopatológico</div></div></div>
      <div class="step"><div class="step-circle pending">8</div><div class="step-body"><div class="step-title" data-t="r8_t">Diagnóstico final</div><div class="step-desc" data-t="r8_d">Junta médica oncológica</div></div></div>
      <div class="step"><div class="step-circle pending">9</div><div class="step-body"><div class="step-title" data-t="r9_t">Plan de tratamiento</div><div class="step-desc" data-t="r9_d">Inicio de tratamiento · Alta</div></div></div>
    </div>
  </div>

  <!-- ══ SMS ══ -->
  <div class="page" id="page-sms">
    <div class="page-header">
      <h2 data-t="sms_h">WhatsApp OncoWarmi</h2>
      <p data-t="sms_p">Tu asistente disponible 24/7</p>
    </div>
    <div class="chat-wrap">
      <div class="chat-header" style="background:#128C7E;">
        <div class="warmi-avatar">🌸</div>
        <div>
          <div style="font-weight:700;font-size:14px;" data-t="warmi_name">WhatsApp OncoWarmi</div>
          <div style="font-size:11px;opacity:.8;" data-t="warmi_stat">● En línea</div>
        </div>
      </div>
      <div class="chat-msgs" id="chat-msgs">
        <div class="msg msg-warmi" data-t="msg1">🌸 Hola María, soy tu navegadora Warmi. Estoy aquí para acompañarte. ¡No estás sola! 💜</div>
        <div class="msg msg-warmi" data-t="msg2">✅ Tu referencia fue aceptada. Tu Historia Clínica se abre el 18 de junio a las 9:00 a.m. – Módulo Admisión 3.</div>
        <div class="msg msg-warmi" data-t="msg3">📋 Lleva: DNI · Hoja de referencia · Informe médico · Resultados previos</div>
      </div>
      <div class="chat-input-row">
        <input type="text" id="chat-input" data-t-ph="sms_ph" placeholder="Escribe tu consulta..." onkeydown="if(event.key==='Enter')sendChat()">
        <button class="btn btn-primary btn-sm" onclick="sendChat()" data-t="btn_send">Enviar</button>
      </div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;">
      <button class="btn btn-ghost btn-sm" onclick="quickMsg('¿Cuándo tengo mi cita?')"    data-t="q1">¿Mi cita?</button>
      <button class="btn btn-ghost btn-sm" onclick="quickMsg('¿Qué documentos debo llevar?')" data-t="q2">Documentos</button>
      <button class="btn btn-ghost btn-sm" onclick="quickMsg('¿Necesito viajar hoy?')"     data-t="q3">¿Viajar hoy?</button>
      <button class="btn btn-ghost btn-sm" onclick="quickMsg('Tengo mucha ansiedad')"       data-t="q4">Apoyo emocional</button>
    </div>
  </div>

  <!-- ══ PSICOLOGÍA ══ -->
  <div class="page" id="page-psicologia">
    <div class="page-header">
      <h2 data-t="psico_h">🧠 Ruta Psicológica</h2>
      <p data-t="psico_p">Apoyo emocional · Psicooncología · Manejo de la ansiedad</p>
    </div>
    <div class="alert alert-pink">
      <strong data-t="psico_al_tit">Esto es normal</strong>
      <span data-t="psico_al_bod">Sentir ansiedad, miedo o tristeza es completamente normal. No estás sola — tenemos apoyo para ti.</span>
    </div>
    <div class="tabs" id="psico-tabs">
      <div class="tab active" onclick="psicoTab('screen')" data-t="pt1">Evaluación</div>
      <div class="tab" onclick="psicoTab('apoyo')"   data-t="pt2">Apoyo Warmi</div>
      <div class="tab" onclick="psicoTab('tecnicas')" data-t="pt3">Técnicas</div>
      <div class="tab" onclick="psicoTab('recursos')" data-t="pt4">Recursos</div>
    </div>

    <div id="psico-screen">
      <div class="card">
        <div style="font-size:14px;font-weight:700;margin-bottom:4px;" data-t="gad_tit">¿Cómo te has sentido esta semana?</div>
        <div style="font-size:12px;color:var(--text2);margin-bottom:14px;" data-t="gad_sub">Responde con honestidad — solo nosotras vemos esto</div>
        <div class="gad-item">
          <div class="gad-q" data-t="gad_q1">1. Me he sentido nerviosa o con mucha preocupación</div>
          <div class="gad-opts">
            <div class="gad-opt" onclick="selectGad(this,0,0)" data-t="gad_o0">Para nada</div>
            <div class="gad-opt" onclick="selectGad(this,0,1)" data-t="gad_o1">Varios días</div>
            <div class="gad-opt" onclick="selectGad(this,0,2)" data-t="gad_o2">Más de la mitad</div>
            <div class="gad-opt" onclick="selectGad(this,0,3)" data-t="gad_o3">Casi siempre</div>
          </div>
        </div>
        <div class="gad-item">
          <div class="gad-q" data-t="gad_q2">2. No pude dejar de preocuparme</div>
          <div class="gad-opts">
            <div class="gad-opt" onclick="selectGad(this,1,0)" data-t="gad_o0">Para nada</div>
            <div class="gad-opt" onclick="selectGad(this,1,1)" data-t="gad_o1">Varios días</div>
            <div class="gad-opt" onclick="selectGad(this,1,2)" data-t="gad_o2">Más de la mitad</div>
            <div class="gad-opt" onclick="selectGad(this,1,3)" data-t="gad_o3">Casi siempre</div>
          </div>
        </div>
        <div class="gad-item">
          <div class="gad-q" data-t="gad_q3">3. Sentí mucho miedo, como si algo terrible fuera a pasar</div>
          <div class="gad-opts">
            <div class="gad-opt" onclick="selectGad(this,2,0)" data-t="gad_o0">Para nada</div>
            <div class="gad-opt" onclick="selectGad(this,2,1)" data-t="gad_o1">Varios días</div>
            <div class="gad-opt" onclick="selectGad(this,2,2)" data-t="gad_o2">Más de la mitad</div>
            <div class="gad-opt" onclick="selectGad(this,2,3)" data-t="gad_o3">Casi siempre</div>
          </div>
        </div>
        <div class="gad-item">
          <div class="gad-q" data-t="gad_q4">4. Me costó mucho relajarme</div>
          <div class="gad-opts">
            <div class="gad-opt" onclick="selectGad(this,3,0)" data-t="gad_o0">Para nada</div>
            <div class="gad-opt" onclick="selectGad(this,3,1)" data-t="gad_o1">Varios días</div>
            <div class="gad-opt" onclick="selectGad(this,3,2)" data-t="gad_o2">Más de la mitad</div>
            <div class="gad-opt" onclick="selectGad(this,3,3)" data-t="gad_o3">Casi siempre</div>
          </div>
        </div>
        <button class="btn btn-pink btn-full" style="margin-top:14px;" onclick="evalGad()" data-t="gad_btn">Ver mi resultado</button>
        <div id="gad-result" style="display:none;margin-top:14px;"></div>
      </div>
    </div>

    <div id="psico-apoyo" style="display:none;">
      <div class="chat-wrap">
        <div class="chat-header" style="background:var(--pink);">
          <div class="warmi-avatar">🧠</div>
          <div>
            <div style="font-weight:700;font-size:14px;" data-t="wpsico_name">Warmi Psicológica</div>
            <div style="font-size:11px;opacity:.8;" data-t="wpsico_sub">Apoyo emocional especializado</div>
          </div>
        </div>
        <div class="chat-msgs" id="psico-msgs">
          <div class="msg msg-warmi" data-t="psico_msg1">💜 Hola, soy Warmi. Estoy aquí para escucharte. Cuéntame cómo te sientes hoy.</div>
        </div>
        <div class="chat-input-row">
          <input type="text" id="psico-input" data-t-ph="psico_ph" placeholder="Cuéntame cómo te sientes..." onkeydown="if(event.key==='Enter')sendPsico()">
          <button class="btn btn-sm" style="background:var(--pink);color:white;" onclick="sendPsico()" data-t="btn_send">Enviar</button>
        </div>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;">
        <button class="btn btn-ghost btn-sm" onclick="quickPsico('Tengo mucho miedo del diagnóstico')" data-t="pq1">Tengo miedo</button>
        <button class="btn btn-ghost btn-sm" onclick="quickPsico('No puedo dormir de la preocupación')" data-t="pq2">No puedo dormir</button>
        <button class="btn btn-ghost btn-sm" onclick="quickPsico('Me siento sola en este proceso')" data-t="pq3">Me siento sola</button>
      </div>
    </div>

    <div id="psico-tecnicas" style="display:none;">
      <div class="card">
        <div style="font-size:14px;font-weight:700;margin-bottom:12px;" data-t="breath_tit">🌬️ Respiración 4-7-8</div>
        <div style="font-size:13px;color:var(--text2);margin-bottom:8px;" data-t="breath_sub">Técnica probada para reducir la ansiedad en minutos</div>
        <div class="breath-circle" id="breath-circle" data-t="breath_start">Presiona\nIniciar</div>
        <div style="text-align:center;margin-top:4px;font-size:12px;color:var(--text2);" id="breath-text" data-t="breath_desc">Ejercicio de respiración guiada</div>
        <button class="btn btn-pink btn-full" id="breath-btn" onclick="startBreath()" style="margin-top:14px;" data-t="breath_btn">🌬️ Iniciar respiración</button>
